---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import ServiceAreaMap from '@components/ServiceAreaMap.astro';
import FaqSection from '@components/FaqSection.astro';
import FinalCta from '@components/FinalCta.astro';
import QuoteForm from '@components/QuoteForm.astro';
import CityLinks from '@components/CityLinks.astro';
import { SITE, tel } from '@config/site';
import { SERVICES, type Faq } from '@config/services';
import { serviceUrl } from '../lib/urls';
import { defaultHero } from '../lib/images';
import { faqPage } from '../lib/schema';

const title = `${SITE.region} Land Clearing & Forestry Mulching`;
const description = `Land clearing across ${SITE.region}: forestry mulching, brush removal, tree and stump removal, lot clearing, fence lines, and site prep. Honest, local crew that knows East Texas brush. Call ${SITE.phoneDisplay} for a fast quote.`;

// Homepage FAQs (rendered + FAQ schema via FaqSection / faqPage).
const homeFaqs: Faq[] = [
  {
    q: 'How much does it cost to clear an acre in Montgomery County?',
    a: 'It depends on what is growing on it and how clean you need it. Light underbrush and forestry mulching cost far less per acre than a full clear, grub, and grade down to bare dirt. Thick yaupon and post oak, large trees, and stump removal all add to it. We walk the property and quote it by the acre or the job so you know the real number before any equipment shows up.',
  },
  {
    q: 'What land clearing work do you do?',
    a: 'Forestry mulching, brush removal, tree and stump removal, lot clearing for new builds, fence-line and right-of-way clearing, underbrush clearing, and grubbing and site prep. One local crew handles the whole job — from a wall of woods to clean, buildable ground — across Montgomery County.',
  },
  {
    q: 'How do I get a quote?',
    a: 'Call us with the acreage, what is growing on it, and what you are trying to do — clear a homesite, open up pasture, mulch the underbrush, or clear a fence line. For most jobs we walk the property to give a firm price. You can also send details through the quote form.',
  },
  {
    q: 'What is forestry mulching, and why is it cheaper?',
    a: 'Forestry mulching uses one machine to grind standing brush, yaupon, and small trees into mulch right where they stand — no burning, no debris piles, and no haul-off cost. Because there is nothing to haul or burn, it is usually the most affordable way to clear underbrush, and the mulch layer it leaves behind helps hold the soil and slow regrowth.',
  },
  {
    q: 'Can you clear my land but keep the big trees?',
    a: 'Yes — selective clearing is one of our most common jobs. We mulch the yaupon and understory and clear only the trees in the way of your build, drive, or fence, leaving the mature post oaks and pines that give the property shade and value. Just point out what you want kept.',
  },
  {
    q: 'What areas do you cover?',
    a: 'Conroe, Montgomery, Magnolia, Willis, New Caney, Splendora, Porter, Pinehurst, Cut and Shoot, Panorama Village, Stagecoach, Dobbin, and the surrounding Montgomery County communities. If you are not sure we reach you, call and ask — we likely do.',
  },
];

const jsonLd = faqPage(homeFaqs) ?? [];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <!-- 1. Simple bold headline — no background image, no subtext -->
  <section class="lp-hero">
    <div class="container">
      <h1>Land Clearing & Forestry Mulching in {SITE.region}</h1>
    </div>
  </section>

  <!-- 2. Photo + quote form -->
  <section class="section-sm">
    <div class="container split">
      <div class="lp-photo">
        <Image
          src={defaultHero}
          alt={`Land clearing and forestry mulching in ${SITE.region}`}
          widths={[480, 760, 1000]}
          sizes="(max-width: 920px) 100vw, 560px"
          fetchpriority="high"
          loading="eager"
        />
      </div>
      <QuoteForm source="home-hero" />
    </div>
  </section>

  <!-- 3. Intro / About -->
  <section class="section section-soft" id="about">
    <div class="container prose">
      <h2>Your Local Land Clearing Crew — Mulching, Brush &amp; Site Prep.</h2>
      <p>
        We’re a full-service land clearing company serving {SITE.region} and the surrounding North
        Houston communities. Overgrown acreage, a wooded lot you bought to build on, underbrush
        choking out your trees, a fence line lost to yaupon, or storm debris that needs hauling out —
        we handle the whole job, and we come to your property to do it.
      </p>
      <p>
        Out here the land is dense East Texas brush, not open prairie: yaupon thickets under post oak
        and pine, sweetgum, briars, and second-growth scrub, often on sandy or damp ground that ruts
        and erodes if it’s cleared carelessly. Tell us the acreage, what’s growing on it, and what
        you’re trying to do, and we’ll give you a straight answer, a real price, and a crew that
        leaves you usable ground — not a field of stumps and debris.
      </p>
      <ul class="checklist">
        <li>Forestry mulching &amp; underbrush clearing</li>
        <li>Brush removal, tree &amp; stump removal</li>
        <li>Lot clearing for new builds &amp; site prep</li>
        <li>Fence-line, right-of-way &amp; easement clearing</li>
      </ul>
    </div>
  </section>

  <!-- 3. What We Do — a section per service (alternating rows) -->
  <section class="section section-soft" id="services">
    <div class="container">
      <div class="section-head">
        <h2>What We Do</h2>
        <p class="lead muted">
          From mulching underbrush to a full clear-and-grub for your build, here’s what we handle for
          {SITE.region} landowners.
        </p>
      </div>

      {SERVICES.map((s, i) => (
        <div class:list={['srow', { reverse: i % 2 === 1 }]}>
          <div class="srow-media">
            <a href={serviceUrl(s)}>
              <Image
                src={s.image}
                alt={s.imageAlt}
                widths={[480, 720, 960]}
                sizes="(max-width: 920px) 100vw, 500px"
                loading="lazy"
                style="border-radius:var(--radius);width:100%;"
              />
            </a>
          </div>
          <div class="srow-body">
            {s.emergency && <span class="badge">Emergency</span>}
            <h3><a href={serviceUrl(s)}>{s.name}</a></h3>
            <p>{s.description}</p>
            <p class="srow-actions">
              <a class="btn btn-primary" href={serviceUrl(s)}>More on {s.short} →</a>
              <a class="btn btn-call" href={tel()}>Call {SITE.phoneDisplay}</a>
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 4. Service across Montgomery County (maps + coverage) -->
  <ServiceAreaMap />

  <!-- 5. Common clearing scenarios — what we solve -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Land You Can’t Use? Let’s Open It Up.</h2>
        <p class="lead muted">
          Most of the calls we get are land that’s gone to brush or raw woods that won’t cooperate
          with a build. Here’s what we turn back into usable ground.
        </p>
      </div>
      <div class="issue-grid">
        <div class="card">
          <h3>Overgrown lots and acreage</h3>
          <p class="muted">
            Yaupon, briars, and scrub take over fast out here — leave a tract a few seasons and you
            can’t walk it, fence it, or see across it. We mulch and clear the brush and hand you back
            open, usable ground.
          </p>
        </div>
        <div class="card">
          <h3>Raw lots before a build</h3>
          <p class="muted">
            Bought a wooded lot to build on? We clear the brush and trees the build needs, grind or
            pull the stumps, and grub the pad to clean, gradeable dirt — while keeping the shade trees
            worth keeping.
          </p>
        </div>
        <div class="card">
          <h3>Fence lines and storm debris</h3>
          <p class="muted">
            Fence lines lost to brush, easements and access roads closing in, or downed trees and
            debris after a storm — we clear the line back to a clean, maintainable strip and haul out
            what’s in the way.
          </p>
        </div>
      </div>
      <p style="text-align:center;margin-top:24px;">
        <a class="btn btn-call btn-lg" href={tel()}>Call {SITE.phoneDisplay}</a>
      </p>
    </div>
  </section>

  <!-- 6. How It Works -->
  <section class="section section-soft">
    <div class="container">
      <div class="section-head">
        <h2>How It Works</h2>
        <p class="lead muted">Three steps, no runaround.</p>
      </div>
      <div class="issue-grid">
        <div class="card">
          <h3>1. Call or request a quote</h3>
          <p class="muted">
            Call {SITE.phoneDisplay} or send the quote form. Tell us where the property is and what
            you’re trying to do and we’ll give you a straight price and a real time.
          </p>
        </div>
        <div class="card">
          <h3>2. We walk the property</h3>
          <p class="muted">
            For most jobs we walk the land with you — how much acreage, what’s growing on it, which
            trees you want kept, and what you’re after. That’s how we quote it honestly by the acre or
            the job.
          </p>
        </div>
        <div class="card">
          <h3>3. We clear it clean</h3>
          <p class="muted">
            We bring the right equipment, do the work on-site, and leave you usable ground — mulched,
            cleared, or grubbed to buildable dirt. No surprises, no field of stumps and debris.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Service area list -->
  <CityLinks
    title={`Service Area — Across ${SITE.region} & North Houston`}
    sub="Land clearing, forestry mulching, and site prep for every community we cover."
  />

  <!-- 8. FAQ -->
  <FaqSection faqs={homeFaqs} title="Questions We Hear a Lot" />

  <!-- Final CTA -->
  <FinalCta />
</BaseLayout>

<style>
  .srow-body .badge {
    display: inline-block;
    background: #b42318;
    color: #fff;
    font-size: 11px;
    font-weight: bold;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: var(--radius);
    margin-bottom: 8px;
  }
  .srow-body h3 {
    font-size: 1.35rem;
    margin-bottom: 8px;
  }
  .srow-body h3 a {
    color: var(--navy);
    text-decoration: none;
  }
  .srow-body h3 a:hover {
    color: var(--green-dark);
  }
  .srow-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }
</style>
